# Weekly Pulse — environment variables
# Copy to .env and fill in values, then export or load in your shell:
#   Windows (PowerShell): Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { $env:$($matches[1])=$matches[2] } }
#   macOS/Linux: set -a && source .env && set +a

# --- Required for full pipeline (Groq summarization) ---
GROQ_API_KEY=

# --- Hosted Google Workspace MCP (Railway) ---
# Default URL is also in config/mcp/servers.json
MCP_SERVER_URL=https://web-production-c5ea8.up.railway.app

# Google Doc ID — from URL: docs.google.com/document/d/DOC_ID/edit
GOOGLE_DOC_ID=

# Email — comma-separated recipients; from address is the Gmail account on MCPServer (Railway OAuth)
PULSE_EMAIL_TO=
PULSE_EMAIL_FROM=

# Optional — required when Railway MCPServer has API_KEY set (see github.com/Sahithi191127/MCPServer)
# MCP_API_KEY=

# --- Production scheduler (Phase 9) — see .env.production.example and DOC/runbook.md ---
# PULSE_ENV=production
# PULSE_EMAIL_MODE=draft
# PULSE_ISO_WEEK_POLICY=auto
# Default embeddings use local BGE-small — no key needed
# OPENAI_API_KEY=
